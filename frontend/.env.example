# Frontend Environment Variables
# -------------------------------------------------------
# LOCAL DEVELOPMENT: copy this file to .env and fill in the values below.
#   cp frontend/.env.example frontend/.env
#
# RENDER / PRODUCTION: do NOT use this file.
#   Set these variables in the Render dashboard under
#   gutmann-frontend → Environment BEFORE triggering a build.
#   React bakes env vars at build time – changing them requires a redeploy.
# -------------------------------------------------------

# URL of the deployed backend API (no trailing slash)
# Local:      http://localhost:3001/api
# Production: https://gutmann-backend.onrender.com/api
REACT_APP_API_URL=http://localhost:3001/api

# URL of the deployed backend for Socket.IO
# Local:      http://localhost:3001
# Production: https://gutmann-backend.onrender.com
REACT_APP_SOCKET_URL=http://localhost:3001

# Supabase project credentials (same for local and production)
REACT_APP_SUPABASE_URL=https://ewjbhcqnkbuxbvstdbnc.supabase.co
